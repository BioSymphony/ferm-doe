    "examples/xylanase-wxz1-2012/outputs/readiness_verdict.md"
  ],
  "claim_level": "public_synthetic_demo",
  "profiles": [
    "screening"
  ],
  "system": {
    "organism_label": "public_demo_system",
    "product_class": "public_demo_product",
    "scale": "public_demo_scale",
    "privacy": "synthetic_or_public_only"
  },
  "doe": {
    "family": "custom_constrained",
    "n_runs": 4,
    "randomized": true,
    "claim": "heuristic",
