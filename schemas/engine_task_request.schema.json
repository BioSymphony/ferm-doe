{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/BioSymphony/ferm-doe/main/schemas/engine_task_request.schema.json",
  "title": "BioSymphony Ferm DoE Engine Task Request",
  "description": "Public-safe routing subset for the richer engine task-request router. This is separate from the compact public task request validated by schemas/task_request.schema.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_kind",
    "request_id",
    "title",
    "summary",
    "data_classification",
    "task",
    "safety"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "request_kind": {
      "const": "ferm_doe_task_request"
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "data_classification": {
      "$ref": "#/$defs/data_classification"
    },
    "campaign": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "campaign_id": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string"
        },
        "organism_or_host": {
          "type": "string"
        },
        "product_or_response": {
          "type": "string"
        },
        "current_format": {
          "type": "string"
        },
        "target_format": {
          "type": "string"
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent",
        "requested_outputs"
      ],
      "properties": {
        "intent": {
          "$ref": "#/$defs/task_intent"
        },
        "priority": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "requested_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path"
        ],
        "properties": {
          "kind": {
            "$ref": "#/$defs/input_kind"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "data_classification": {
            "$ref": "#/$defs/data_classification"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preferred_lane": {
          "$ref": "#/$defs/lane"
        },
        "preferred_issue_pack": {
          "$ref": "#/$defs/issue_pack"
        },
        "activate_first_wave_only": {
          "type": "boolean"
        },
        "remote_compute_allowed": {
          "type": "boolean"
        },
        "linear_project_hint": {
          "type": "string"
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contains_secrets",
        "contains_private_process_data"
      ],
      "properties": {
        "contains_secrets": {
          "const": false
        },
        "contains_private_process_data": {
          "type": "boolean"
        },
        "private_data_handling": {
          "enum": [
            "not_applicable",
            "sanitized_summary_only",
            "secure_reference_only"
          ]
        },
        "private_data_ref": {
          "type": "string"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_by": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "data_classification": {
      "enum": [
        "public",
        "synthetic",
        "sanitized"
      ]
    },
    "input_kind": {
      "enum": [
        "campaign_manifest",
        "run_ledger",
        "factor_space",
        "reagent_inventory",
        "equipment_inventory",
        "assay_protocol",
        "evidence_table",
        "issue_pack",
        "compute_policy",
        "results_table",
        "other"
      ]
    },
    "issue_pack": {
      "enum": [
        "fermentation-readiness-v0",
        "scientific-swarm-v0",
        "evidence-executor-v0",
        "doe-parity-v1",
        "adaptive-wave2-assay-power-v0",
        "campaign-arms-v1",
        "none"
      ]
    },
    "lane": {
      "enum": [
        "codex",
        "symphony",
        "claude",
        "human_review",
        "runpod",
        "external"
      ]
    },
    "task_intent": {
      "enum": [
        "campaign_intake",
        "readiness_audit",
        "historical_data_rescue",
        "assay_readiness",
        "factor_universe",
        "feasibility_audit",
        "design_tournament",
        "wave2_planning",
        "evidence_execution",
        "issue_pack",
        "compute_handoff",
        "repo_maintenance",
        "unknown"
      ]
    }
  }
}
